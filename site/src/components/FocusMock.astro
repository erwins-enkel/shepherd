---
// Faux Shepherd UI for the hero — a CSS/HTML render of the app's DEFAULT
// "focus" view: the herd in the left sidebar (many sessions) + one focused
// session pane (header · tab strip · live terminal). Mirrors the real
// components Herd/UnitRow (sidebar) + Viewport (focus pane) + the "All ▦ /
// Focus ⌖" toggle in ActionBar.
//
// Designations (TASK-NN), repo/branch names and terminal lines are verbatim
// product-shaped data, NOT marketing copy — intentionally unpolished.
//
// Status semantics by meaning (matching the app's STATUS_COLOR tokens):
//   running/busy -> --amber   ready -> --green (actionable-complete only)
//   in-review -> --blue   idle/done -> --slate   blocked -> --red

type Status = "busy" | "ready" | "review" | "idle" | "blocked";

interface Row {
  id: string;
  repo: string;
  status: Status;
  label: string;
  pr?: string;
  selected?: boolean;
}

const STATUS_LABEL: Record<Status, string> = {
  busy: "BUSY",
  ready: "READY",
  review: "REVIEW",
  idle: "IDLE",
  blocked: "BLOCKED",
};

const rows: Row[] = [
  { id: "TASK-07", repo: "shepherd", status: "busy", label: STATUS_LABEL.busy, selected: true },
  { id: "TASK-11", repo: "shepherd", status: "ready", label: STATUS_LABEL.ready, pr: "#482" },
  { id: "TASK-04", repo: "web", status: "review", label: STATUS_LABEL.review, pr: "#479" },
  { id: "TASK-02", repo: "docs", status: "idle", label: STATUS_LABEL.idle },
  { id: "TASK-15", repo: "api", status: "blocked", label: STATUS_LABEL.blocked },
];

// Live terminal lines for the focused session (TASK-07).
const termLines = [
  { k: "cmd", t: "> Edit src/auth/session.ts" },
  { k: "out", t: "⎿ rotate refresh token on renew" },
  { k: "cmd", t: "> Bash bun test ./test/session.test.ts" },
  { k: "ok", t: "⎿ 14 pass · 0 fail (1.2s)" },
  { k: "cmd", t: "> Read src/auth/cookies.ts" },
];
---

<section class="app" aria-label="Shepherd focus view preview">
  <div class="titlebar">
    <span class="dots" aria-hidden="true"
      ><span class="dot"></span><span class="dot"></span><span class="dot"></span
      ></span
    >
    <span class="toggle" aria-hidden="true">
      <span class="seg">All ▦</span><span class="seg on">Focus ⌖</span>
    </span>
  </div>

  <div class="body">
    <aside class="side" aria-label="Herd">
      <p class="side-head">HERD · {rows.length}</p>
      <ul class="rows">
        {
          rows.map((r) => (
            <li class={`urow s-${r.status}${r.selected ? " sel" : ""}`}>
              <span class={`pip s-${r.status}`} aria-hidden="true" />
              <span class="rid">{r.id}</span>
              <span class="rrepo">{r.repo}</span>
              {r.pr && <span class="prbadge">PR {r.pr}</span>}
              <span class="rstatus">{r.label}</span>
            </li>
          ))
        }
      </ul>
    </aside>

    <div class="focus s-busy">
      <div class="vp-head">
        <span class="pip s-busy" aria-hidden="true"></span>
        <span class="desig">TASK-07</span>
        <span class="ctx">· shepherd · fix/auth-session</span>
        <span class="spacer"></span>
        <span class="model">Sonnet</span>
        <span
          class="gauge"
          role="meter"
          aria-label="5-hour usage"
          aria-valuenow="62"
          aria-valuemin="0"
          aria-valuemax="100"
        >
          <span class="gtrack" aria-hidden="true"
            ><span class="gfill" style="width: 62%"></span></span
          >
        </span>
      </div>

      <div class="tabs" aria-hidden="true">
        <span class="tab on">Terminal</span>
        <span class="tab">Activity</span>
        <span class="tab">Diff</span>
        <span class="tab">Preview</span>
      </div>

      <div class="term">
        {
          termLines.map((l) => (
            <p class={`tl ${l.k}`}>{l.t}</p>
          ))
        }
        <p class="tl cursor">› <span class="caret" aria-hidden="true"></span></p>
      </div>
    </div>
  </div>
</section>

<style>
  .app {
    width: 100%;
    max-width: 40rem;
    background: var(--panel);
    border: 1px solid var(--panel-2);
    border-radius: 0.85rem;
    box-shadow: 0 24px 60px -28px color-mix(in srgb, var(--bg) 75%, transparent);
    overflow: hidden;
    font-family: var(--font-mono);
  }

  .titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0.7rem;
    background: var(--panel-2);
  }

  .dots {
    display: flex;
    gap: 0.4rem;
  }
  .dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--ink-dim);
  }

  .toggle {
    display: inline-flex;
    border: 1px solid color-mix(in srgb, var(--ink-dim) 45%, transparent);
    border-radius: 0.4rem;
    overflow: hidden;
    font-size: 0.66rem;
  }
  .seg {
    padding: 0.16rem 0.5rem;
    color: var(--ink-muted);
  }
  .seg.on {
    background: color-mix(in srgb, var(--amber) 22%, transparent);
    color: var(--ink);
  }

  .body {
    display: grid;
    grid-template-columns: 11rem 1fr;
    min-height: 16.5rem;
  }

  /* sidebar (the herd) */
  .side {
    border-right: 1px solid var(--panel-2);
    padding: 0.6rem 0.5rem;
    background: color-mix(in srgb, var(--bg) 45%, var(--panel));
  }
  .side-head {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    padding: 0 0.3rem 0.5rem;
  }
  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.2rem;
  }
  .urow {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.35rem;
    padding: 0.34rem 0.4rem;
    border-radius: 0.4rem;
    border-left: 2px solid transparent;
    font-size: 0.68rem;
  }
  .rid {
    flex: 0 0 auto;
  }
  .prbadge,
  .rstatus {
    flex: 0 0 auto;
  }
  .urow.sel {
    background: color-mix(in srgb, var(--amber) 12%, transparent);
    border-left-color: var(--amber);
  }
  .rid {
    color: var(--ink);
    font-weight: 500;
  }
  .rrepo {
    flex: 1 1 auto;
    min-width: 0;
    color: var(--ink-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .prbadge {
    font-size: 0.58rem;
    color: var(--green);
  }
  .rstatus {
    font-size: 0.56rem;
    letter-spacing: 0.04em;
    color: var(--ink-muted);
  }
  .s-blocked .rstatus {
    color: var(--red);
  }

  /* status pips */
  .pip {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .pip.s-busy {
    background: var(--amber);
  }
  .pip.s-ready {
    background: var(--green);
  }
  .pip.s-review {
    background: var(--blue);
  }
  .pip.s-idle {
    background: var(--slate);
  }
  .pip.s-blocked {
    background: var(--red);
  }

  /* focus pane (Viewport) */
  .focus {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .vp-head {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 0.7rem;
    border-bottom: 1px solid var(--panel-2);
    /* tinted header when working */
    background: color-mix(in srgb, var(--amber) 9%, transparent);
    font-size: 0.72rem;
  }
  .desig {
    flex: 0 0 auto;
    white-space: nowrap;
    color: var(--ink);
    font-weight: 600;
  }
  .ctx {
    flex: 0 1 auto;
    min-width: 0;
    color: var(--ink-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .spacer {
    flex: 1;
  }
  .model {
    font-size: 0.62rem;
    color: var(--ink-muted);
  }
  .gauge {
    flex: 0 0 auto;
  }
  .gtrack {
    display: block;
    width: 2.6rem;
    height: 0.32rem;
    border-radius: 0.32rem;
    background: var(--panel-2);
    overflow: hidden;
  }
  .gfill {
    display: block;
    height: 100%;
    background: var(--gradient-amber-green);
  }

  .tabs {
    display: flex;
    gap: 0.2rem;
    padding: 0.4rem 0.6rem 0;
    border-bottom: 1px solid var(--panel-2);
  }
  .tab {
    padding: 0.22rem 0.5rem;
    font-size: 0.64rem;
    color: var(--ink-muted);
    border-bottom: 2px solid transparent;
  }
  .tab.on {
    color: var(--ink);
    border-bottom-color: var(--amber);
  }

  .term {
    padding: 0.7rem 0.8rem;
    font-size: 0.72rem;
    line-height: 1.65;
    flex: 1;
  }
  .tl {
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tl.cmd {
    color: var(--ink);
  }
  .tl.out {
    color: var(--ink-muted);
  }
  .tl.ok {
    color: var(--green);
  }
  .tl.cursor {
    color: var(--ink-muted);
  }
  .caret {
    display: inline-block;
    width: 0.5rem;
    height: 0.95rem;
    vertical-align: text-bottom;
    background: var(--amber);
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 30rem) {
    /* on narrow viewports drop the sidebar, keep the focus pane */
    .body {
      grid-template-columns: 1fr;
    }
    .side {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .caret {
      animation: none;
    }
  }
</style>
