{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  // ui/ is a separate SvelteKit package with its own tsconfig + `bun run check`
  // (svelte-check resolves the $lib alias and .svelte files, which this server
  // tsconfig cannot). Keep the root type-check scoped to server code.
  "exclude": ["node_modules", "ui"]
}
