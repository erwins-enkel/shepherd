#!/usr/bin/env sh
# Full CI-equivalent gate. Mirrors .github/workflows/ci.yml so failures
# surface locally before they ever reach a PR. Root + ui are separate
# packages with their own deps — install both before pushing.
set -e

echo "▶ pre-push: lint · typecheck · tests · build"

echo "→ prettier --check"
bunx prettier --check .

echo "→ eslint"
bun run lint

echo "→ root typecheck (tsc)"
bun run typecheck

echo "→ ui svelte-check"
(cd ui && bun run check)

echo "→ root tests"
# server.test.ts builds a throwaway git repo under SHEPHERD_REPO_ROOT;
# point it at a temp dir so we never touch the operator's real repo root.
SHEPHERD_REPO_ROOT="$(mktemp -d)" bun test ./test

echo "→ ui tests"
(cd ui && bun run test)

echo "→ ui build"
(cd ui && bun run build)

echo "✓ pre-push passed"
