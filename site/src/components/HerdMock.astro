---
// Faux Shepherd UI — a CSS/HTML render of the herd panel, built to read like
// the real terminal-native instrument panel (not a generic SaaS card grid).
//
// Designations (TASK-07 etc.) and the terminal activity lines are verbatim
// product data, NOT marketing copy — intentionally not "polished".
//
// Status semantics are by meaning (matching the app's tokens):
//   running -> --amber   ready -> --green (actionable-complete only)
//   in-review -> --blue  done/parked -> --slate   blocked -> --red

type Status = "running" | "ready" | "review" | "done";

interface Agent {
  id: string;
  status: Status;
  label: string;
  lines: string[];
}

const STATUS_LABEL: Record<Status, string> = {
  running: "RUNNING",
  ready: "READY",
  review: "IN REVIEW",
  done: "DONE",
};

const agents: Agent[] = [
  {
    id: "TASK-07",
    status: "running",
    label: STATUS_LABEL.running,
    lines: ["> Edit src/auth/session.ts", "  bun test ./test/session …"],
  },
  {
    id: "TASK-11",
    status: "ready",
    label: STATUS_LABEL.ready,
    lines: ["✓ CI green · 3 commits", "  PR #482 ready to merge"],
  },
  {
    id: "TASK-04",
    status: "review",
    label: STATUS_LABEL.review,
    lines: ["⟳ critic reviewing PR #479", "  2 findings · steering back"],
  },
  {
    id: "TASK-02",
    status: "done",
    label: STATUS_LABEL.done,
    lines: ["✓ merged via train", "  worktree archived"],
  },
];
---

<section class="herd" aria-label="Shepherd herd preview">
  <header class="head">
    <span class="title">HERD</span>
    <span class="meta">4 sessions</span>
    <span class="spacer"></span>
    <span
      class="gauge"
      role="meter"
      aria-label="5-hour usage"
      aria-valuenow="62"
      aria-valuemin="0"
      aria-valuemax="100"
    >
      <span class="gauge-label">5h usage</span>
      <span class="gauge-track" aria-hidden="true">
        <span class="gauge-fill" style="width: 62%"></span>
      </span>
      <span class="gauge-pct">62%</span>
    </span>
  </header>

  <ul class="cards">
    {
      agents.map((a) => (
        <li class={`card s-${a.status}`}>
          <div class="card-top">
            <span class="pip" aria-hidden="true" />
            <span class="desig">{a.id}</span>
            <span class="status">{a.label}</span>
          </div>
          <div class="term">
            {a.lines.map((line) => (
              <div class="line">{line}</div>
            ))}
          </div>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .herd {
    width: 100%;
    background: var(--panel);
    border: 1px solid var(--panel-2);
    border-radius: 0.9rem;
    box-shadow:
      0 1px 0 var(--panel-2) inset,
      0 24px 60px -36px var(--bg);
    overflow: hidden;
  }

  .head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.75rem 1rem;
    background: var(--panel-2);
    border-bottom: 1px solid var(--bg);
  }

  .title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-dim);
  }

  .spacer {
    flex: 1;
  }

  /* token-usage gauge */
  .gauge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .gauge-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-dim);
  }

  .gauge-track {
    display: block;
    width: 4.5rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--bg);
    overflow: hidden;
  }

  .gauge-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: var(--gradient-amber-green);
  }

  .gauge-pct {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-muted);
  }

  .cards {
    list-style: none;
    margin: 0;
    padding: 0.8rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.7rem;
  }

  .card {
    background: var(--bg);
    border: 1px solid var(--panel-2);
    border-radius: 0.6rem;
    padding: 0.7rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pip {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    flex: 0 0 auto;
  }

  .desig {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--ink);
  }

  .status {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 0.1rem 0.4rem;
    border-radius: 0.3rem;
  }

  .term {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--ink-muted);
  }

  .line {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ---- status semantics (by meaning) ---- */
  .s-running .pip {
    background: var(--amber);
  }
  .s-running .status {
    color: var(--amber);
    background: color-mix(in srgb, var(--amber) 16%, transparent);
  }

  .s-ready .pip {
    background: var(--green);
  }
  .s-ready .status {
    color: var(--green);
    background: color-mix(in srgb, var(--green) 16%, transparent);
  }

  .s-review .pip {
    background: var(--blue);
  }
  .s-review .status {
    color: var(--blue);
    background: color-mix(in srgb, var(--blue) 18%, transparent);
  }

  .s-done {
    opacity: 0.78;
  }
  .s-done .pip {
    background: var(--slate);
  }
  .s-done .status {
    color: var(--ink-muted);
    background: color-mix(in srgb, var(--slate) 22%, transparent);
  }

  /* live: only the running pip pulses, transform/opacity only */
  .s-running .pip {
    animation: pip-pulse 1.8s ease-in-out infinite;
  }

  @keyframes pip-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.45;
      transform: scale(0.82);
    }
  }

  @media (max-width: 420px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .s-running .pip {
      animation: none;
    }
  }
</style>
