# Normalize to LF and let git auto-detect true binaries.
* text=auto eol=lf

# Source/text files are always diffed as text: a stray control byte (e.g. a NUL
# that once crept into a .svelte key separator) must never flip them to a binary
# diff. `diff` forces textual diffing even when a blob trips git's NUL heuristic.
*.ts    text diff
*.tsx   text diff
*.js    text diff
*.mjs   text diff
*.cjs   text diff
*.svelte text diff
*.json  text diff
*.css   text diff
*.html  text diff
*.md    text diff
*.yml   text diff
*.yaml  text diff
*.sh    text eol=lf diff

# Vendored, minified inlang/Paraglide plugins (copied verbatim into ui/ and
# extension/). Not our source — mark generated + vendored so linguist and code
# analysis skip them and diffs collapse. Hand-editing them would diverge from the
# upstream copy and risk breaking the Paraglide compiler.
**/project.inlang/plugins/** linguist-generated=true linguist-vendored=true
