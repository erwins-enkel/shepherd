{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  // ui/, extension/, site/ and docs-site/ are separate packages with their own
  // tsconfig + check command (svelte-check for ui, chrome/vite-client types for
  // the extension, `astro check` for the static marketing + docs sites — none of
  // which this server tsconfig provides). Keep the root type-check scoped to
  // server code.
  "exclude": ["node_modules", "ui", "extension", "site", "docs-site"]
}
