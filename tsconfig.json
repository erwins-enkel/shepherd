{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  // ui/ and extension/ are separate packages with their own tsconfig + `bun run
  // check` (svelte-check resolves $lib/.svelte for ui, chrome/vite-client types
  // for the extension — neither of which this server tsconfig provides). Keep
  // the root type-check scoped to server code.
  "exclude": ["node_modules", "ui", "extension"]
}
