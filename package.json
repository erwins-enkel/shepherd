{
  "name": "shepherd",
  "version": "1.38.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "test": "bun test ./test",
    "lint": "eslint --cache --cache-strategy content --cache-location .cache/eslint --no-error-on-unmatched-pattern src test examples ui/src ci/onboarding-harness deploy",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "start": "bun run src/index.ts",
    "update": "bash deploy/update.sh",
    "prepare": "husky; node scripts/register-merge-driver.mjs",
    "onboarding:test": "bun run ci/onboarding-harness/run.ts",
    "check:glossary": "node scripts/check-glossary.mjs"
  },
  "lint-staged": {
    "*.{ts,js,json,css,html,md,svelte}": "prettier --write --cache --cache-strategy content --cache-location .cache/prettier",
    "*.{ts,svelte}": "eslint --cache --cache-strategy content --cache-location .cache/eslint --fix"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^26.0.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^10.6.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.5",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "jsonrepair": "^3.14",
    "node-pty": "^1.1.0",
    "web-push": "^3.6.7"
  }
}
