---
// The "opinionated about how agent-built software ships" section — the
// discipline layer. Copy faithful to README "Opinionated by design".
interface Gate {
  name: string;
  body: string;
}

const gates: Gate[] = [
  {
    name: "Plan gate",
    body: "Every autonomous plan faces an adversarial read-only reviewer before any code is written.",
  },
  {
    name: "Critic",
    body: "Every PR's full diff is reviewed the moment CI goes green; findings can flow back to the author automatically.",
  },
  {
    name: "Learnings",
    body: "House rules distilled from past failures are injected into every new agent in the repo; ones that stop helping retire themselves, and recurring ones promote across repos.",
  },
  {
    name: "Merge train",
    body: "Nothing lands while behind its base — a stale PR is sent back to its agent to rebase, and CI and the critic re-run first.",
  },
  {
    name: "Manual operator steps",
    body: "Human-only steps a PR declares — env vars, migrations, DNS cutovers — are surfaced and hold auto-merge until they are acknowledged.",
  },
  {
    name: "Hygiene gates",
    body: "CI and the pre-push hook enforce linear branches, locale-catalog parity, feature-catalog completeness, and a dead-code / complexity audit.",
  },
];
---

<section class="guard" aria-labelledby="guard-h">
  <div class="inner">
    <div class="lead">
      <p class="eyebrow">Opinionated by design</p>
      <h2 id="guard-h">
        Running many agents is the easy half; keeping their output shippable is
        the actual product.
      </h2>
      <p class="sub">
        Shepherd institutionalizes the practices a careful team would otherwise
        enforce by hand, as per-repo automation — the discipline layer around
        the sessions, not just more panels.
      </p>
    </div>

    <ul class="gates">
      {
        gates.map((g) => (
          <li class="gate">
            <span class="tag">{g.name}</span>
            <p>{g.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .guard {
    padding: clamp(3rem, 8vw, 5.5rem) 1.5rem;
    border-top: 1px solid var(--panel-2);
    background: var(--panel);
  }

  .inner {
    max-width: 72rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 3rem);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 0.6rem;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3.6vw, 2.2rem);
    letter-spacing: -0.02em;
  }

  .sub {
    margin-top: 1rem;
    max-width: 36rem;
    color: var(--ink-muted);
    font-size: 1.05rem;
  }

  .gates {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }

  .gate {
    display: grid;
    gap: 0.4rem 1rem;
    grid-template-columns: 1fr;
    padding: 1rem 1.2rem;
    background: var(--bg);
    border: 1px solid var(--panel-2);
    border-radius: 0.7rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--green);
  }

  .gate p {
    color: var(--ink-muted);
    font-size: 0.95rem;
  }

  @media (min-width: 900px) {
    .inner {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: start;
    }
    .gate {
      grid-template-columns: 9rem 1fr;
      align-items: baseline;
    }
  }
</style>
