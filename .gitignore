node_modules/
.svelte-kit/
build/
dist/
.env
.env.*
*.db
*.db-shm
*.db-wal
.DS_Store

# Superpowers tool state (planning docs in /docs/superpowers/ ARE tracked)
.superpowers/

# Transient agent worktrees (Claude Code isolation checkouts)
/.claude/worktrees/
.shaping/
.squad/

# Runtime upload staging (New-Task attachments, screenshots)
.shepherd-uploads/

# Plan-gate working artifacts written into the live worktree (never committed)
.shepherd-plan.md
.shepherd-plan-review.json

# Agent-declared live-preview port hint (transient, never committed)
.shepherd-preview

# Self-hosted CI runner: never commit a filled-in env; keep the example tracked
# (the global `.env.*` rule above would otherwise swallow .env.example).
ci/self-hosted-runner/.env
!ci/self-hosted-runner/.env.example
