<script>
  // Pause the looping animation while it is off-screen. Pure enhancement:
  // with JS disabled the CSS animation just plays without pausing.
  const fig = document.querySelector<HTMLElement>(".pipe-anim");
  if (fig && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) fig.classList.toggle("is-paused", !e.isIntersecting);
      },
      { threshold: 0 },
    );
    io.observe(fig);
  }
</script>
