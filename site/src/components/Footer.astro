---
// Footer landmark: GitHub link, exact license (Business Source License 1.1 ©
// 2026 Erwins Enkel GmbH, from ./LICENSE), and a no-affiliation disclaimer.
const GITHUB_URL = "https://github.com/erwins-enkel/shepherd";
const LICENSE_URL =
  "https://github.com/erwins-enkel/shepherd/blob/main/LICENSE";
// First-party docs site — same-tab navigation (no target="_blank").
const DOCS_URL = "https://docs.shepherd.run";
// Legal notice (§ 5 DDG) — first-party page, same-tab navigation.
const IMPRESSUM_URL = "/impressum";
// Operating company behind Shepherd.
const ERWINS_ENKEL_URL = "https://www.erwins-enkel.dev/";
---

<footer class="footer" aria-label="Site footer">
  <div class="inner">
    <div class="top">
      <span class="wordmark">shepherd</span>
      <nav class="flinks" aria-label="Footer">
        <a
          href={GITHUB_URL}
          rel="noopener noreferrer"
          target="_blank"
          data-track="cta_github"
          data-track-location="footer">GitHub</a
        >
        <a href={DOCS_URL} data-track="cta_docs" data-track-location="footer">Docs</a>
        <a href={LICENSE_URL} rel="noopener noreferrer" target="_blank"
          >License</a
        >
        <a href={IMPRESSUM_URL}>Imprint</a>
      </nav>
    </div>

    <p class="license">
      Business Source License 1.1 © 2026 <a
        href={ERWINS_ENKEL_URL}
        rel="noopener noreferrer"
        target="_blank">Erwins Enkel GmbH</a
      >
    </p>

    <p class="disclaimer">
      Not affiliated with Anthropic. Claude and Anthropic are trademarks of
      Anthropic, PBC.
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: clamp(2.5rem, 6vw, 4rem) 1.5rem;
    border-top: 1px solid var(--panel-2);
    background: var(--panel);
  }

  .inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--ink);
  }

  .flinks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    font-size: 0.95rem;
  }

  .flinks a {
    color: var(--ink-muted);
    border-bottom: 1px solid transparent;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .flinks a:hover {
    color: var(--ink);
    border-color: var(--green);
  }

  .flinks a:focus-visible {
    outline: 2px solid var(--green);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .license {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink-muted);
  }

  .license a {
    color: var(--ink);
    border-bottom: 1px solid var(--panel-2);
    transition: border-color 0.15s ease;
  }

  .license a:hover {
    border-color: var(--green);
  }

  .license a:focus-visible {
    outline: 2px solid var(--green);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .disclaimer {
    font-size: 0.82rem;
    color: var(--ink-muted);
    max-width: 40rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .flinks a,
    .license a {
      transition: none;
    }
  }
</style>
